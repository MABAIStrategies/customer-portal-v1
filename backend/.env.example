# Apex Phase-1 backend — copy to .env (gitignored) and fill in.

# Licensed retrieval (preferred). Get a free 30-day dev key at developer.attomdata.com.
# When set, ATTOM is the primary source for owner/parcel/legal/chain/mortgages.
ATTOM_API_KEY=

# Local server port (optional; default 8787)
# PORT=8787

# --- Legacy / fallback only (no key needed) ---
# With no ATTOM_API_KEY, the backend falls back to scraping the free public
# NCC Parcel Search (assessor) for owner/parcel/tax/chain. Judgments are always
# a manual step. The credentialed PAX/CourtConnect scrapers are shelved on ToS grounds.
